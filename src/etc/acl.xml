<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Gubee_Integration::catalog" title="Gubee"></resource>
                <resource id="Gubee_Integration::Queue" title="Queue" sortOrder="10">
                    <resource id="Gubee_Integration::Queue_save" title="Save Queue" sortOrder="10"/>
                    <resource id="Gubee_Integration::Queue_delete" title="Delete Queue" sortOrder="20"/>
                    <resource id="Gubee_Integration::Queue_update" title="Update Queue" sortOrder="30"/>
                    <resource id="Gubee_Integration::Queue_view" title="View Queue" sortOrder="40"/>
                </resource>
                <resource id="Gubee_Integration::Log" title="Log" sortOrder="10">
                    <resource id="Gubee_Integration::Log_save" title="Save Log" sortOrder="10"/>
                    <resource id="Gubee_Integration::Log_delete" title="Delete Log" sortOrder="20"/>
                    <resource id="Gubee_Integration::Log_update" title="Update Log" sortOrder="30"/>
                    <resource id="Gubee_Integration::Log_view" title="View Log" sortOrder="40"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
