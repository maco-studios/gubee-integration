<?xml version="1.0" ?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="Gubee\SDK\Gubee" type="Gubee\Integration\Service\Client"/>
    <preference for="Gubee\Integration\Api\QueueRepositoryInterface" type="Gubee\Integration\Model\QueueRepository"/>
    <preference for="Gubee\Integration\Api\Data\QueueInterface" type="Gubee\Integration\Model\Queue"/>
    <preference for="Gubee\Integration\Api\Data\QueueSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>

    <virtualType name="Gubee\Integration\Model\ResourceModel\Queue\Grid\Collection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">gubee_integration_queue</argument>
            <argument name="resourceModel" xsi:type="string">Gubee\Integration\Model\ResourceModel\Queue\Collection</argument>
        </arguments>
    </virtualType>
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="gubee_integration_queue_listing_data_source" xsi:type="string">Gubee\Integration\Model\ResourceModel\Queue\Grid\Collection</item>
                <item name="gubee_integration_log_listing_data_source" xsi:type="string">Gubee\Integration\Model\ResourceModel\Log\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

    <preference for="Gubee\Integration\Api\LogRepositoryInterface" type="Gubee\Integration\Model\LogRepository"/>
