        </arguments>
    </type>

    <type name="Gubee\Integration\Command\AbstractCommand">
        <arguments>
            <argument name="logger" xsi:type="object">Gubee\Integration\Model\Logger</argument>
        </arguments>
    </type>
    <type name="Gubee\Integration\Model\Queue\Manager">
        <arguments>
            <argument name="logger" xsi:type="object">Gubee\Integration\Model\Logger</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="Gubee\Integration\Command\Gubee\Token\RenewCommand" xsi:type="object">Gubee\Integration\Command\Gubee\Token\RenewCommand</item>
            </argument>
        </arguments>
    </type>

    <type name="Gubee\Integration\Service\Model\Catalog\Product\Attribute">
        <arguments>
            <argument name="strategies" xsi:type="array">
                <item name="attrType" xsi:type="object">Gubee\Integration\Service\Hydration\Catalog\Product\Attribute\AttrTypeHydrator</item>
                <item name="label" xsi:type="object">Gubee\Integration\Service\Hydration\Catalog\Product\Attribute\LabelHydrator</item>
                <item name="name" xsi:type="object">Gubee\Integration\Service\Hydration\Catalog\Product\Attribute\NameHydrator</item>
                <item name="options" xsi:type="object">Gubee\Integration\Service\Hydration\Catalog\Product\Attribute\OptionsHydrator</item>
                <item name="required" xsi:type="object">Gubee\Integration\Service\Hydration\Catalog\Product\Attribute\RequiredHydrator</item>
