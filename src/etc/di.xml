    <virtualType name="Gubee\Integration\Model\ResourceModel\Log\Grid\Collection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">gubee_integration_log</argument>
            <argument name="resourceModel" xsi:type="string">Gubee\Integration\Model\ResourceModel\Log\Collection</argument>
        </arguments>
    </virtualType>

    <type name="Gubee\Integration\Library\Setup\Migration\Context">
        <arguments>
            <argument name="logger" xsi:type="object">Gubee\Integration\Model\Logger</argument>
        </arguments>
    </type>

    <type name="Gubee\Integration\Command\AbstractCommand">
        <arguments>
            <argument name="logger" xsi:type="object">Gubee\Integration\Model\Logger</argument>
        </arguments>
    </type>
    <type name="Gubee\Integration\Model\Queue\Manager">
        <arguments>
            <argument name="logger" xsi:type="object">Gubee\Integration\Model\Logger</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="Gubee\Integration\Command\Gubee\Token\RenewCommand" xsi:type="object">Gubee\Integration\Command\Gubee\Token\RenewCommand</item>
            </argument>
        </arguments>
    </type>

    <type name="Gubee\Integration\Service\Model\Catalog\Product\Attribute">
