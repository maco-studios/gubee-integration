            </argument>
        </arguments>
    </type>

    <type name="Gubee\Integration\Service\Model\Catalog\Category">
        <arguments>
            <argument name="strategies" xsi:type="array">
                <item name="active" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\Category\ActiveHydrator</item>
                <item name="description" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\Category\DescriptionHydrator</item>
