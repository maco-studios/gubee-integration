                <item name="name" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\NameHydrator</item>
                <item name="prices" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\Variation\PricesHydrator</item>
                <item name="sku" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\Variation\SkuHydrator</item>
