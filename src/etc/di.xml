                <item name="status" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\StatusHydrator</item>
                <item name="stocks" xsi:type="string">Gubee\Integration\Service\Hydration\Catalog\Product\Variation\StocksHydrator</item>
