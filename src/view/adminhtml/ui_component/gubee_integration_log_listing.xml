<?xml version="1.0" ?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">gubee_integration_log_listing.gubee_integration_log_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>gubee_integration_log_columns</spinner>
        <deps>
            <dep>gubee_integration_log_listing.gubee_integration_log_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="gubee_integration_log_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">log_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Gubee_Integration::Log</aclResource>
        <dataProvider name="gubee_integration_log_listing_data_source" class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>log_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="gubee_integration_log_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>log_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="log_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Log ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="message" class="Gubee\Integration\Ui\Component\Log\Listing\Column\Message">
            <settings>
                <filter>text</filter>
                <label translate="true">Message</label>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
            </settings>
        </column>
        <column name="level" class="Gubee\Integration\Ui\Component\Log\Listing\Column\Level">
            <settings>
                <options class="Gubee\Integration\Model\Log\Source\Level"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <label translate="true">Level</label>
            </settings>
        </column>
        <column name="context" class="Gubee\Integration\Ui\Component\Log\Listing\Column\Context">
            <settings>
                <filter>text</filter>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <label translate="true">Context</label>
            </settings>
        </column>
        <column name="created_at">
            <settings>
                <filter>date</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
    </columns>
</listing>
