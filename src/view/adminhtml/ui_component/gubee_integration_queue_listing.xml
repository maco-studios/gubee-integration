<?xml version="1.0" ?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">gubee_integration_queue_listing.gubee_integration_queue_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>gubee_integration_queue_columns</spinner>
        <deps>
            <dep>gubee_integration_queue_listing.gubee_integration_queue_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="gubee_integration_queue_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">queue_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>Gubee_Integration::Queue</aclResource>
        <dataProvider name="gubee_integration_queue_listing_data_source" class="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>queue_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="gubee_integration_queue_columns">
        <selectionsColumn name="ids">
            <settings>
                <indexField>queue_id</indexField>
            </settings>
        </selectionsColumn>
        <column name="queue_id">
            <settings>
                <filter>textRange</filter>
                <label translate="true">Queue ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="process">
            <settings>
                <filter>text</filter>
                <label translate="true">Process</label>
            </settings>
        </column>
        <column name="payload">
            <settings>
                <filter>text</filter>
                <label translate="true">Payload</label>
            </settings>
        </column>
        <column name="status" class="Gubee\Integration\Ui\Component\Queue\Listing\Column\Status">
            <settings>
                <options class="Gubee\Integration\Model\Queue\Source\Status"/>
                <filter>select</filter>
                <dataType>select</dataType>
                <bodyTmpl>ui/grid/cells/html</bodyTmpl>
                <label translate="true">Status</label>
            </settings>
        </column>
        <column name="attempts">
            <settings>
                <filter>numberRange</filter>
                <label translate="true">Attempts</label>
            </settings>
        </column>
        <column name="executed_at">
            <settings>
                <filter>date</filter>
                <label translate="true">Executed At</label>
            </settings>
        </column>
        <column name="created_at">
            <settings>
                <filter>date</filter>
                <dataType>date</dataType>
                <label translate="true">Created At</label>
            </settings>
        </column>
        <actionsColumn name="actions" class="Gubee\Integration\Ui\Component\Queue\Listing\Column\Actions">
            <settings>
                <label translate="true">Actions</label>
            </settings>
        </actionsColumn>
    </columns>
</listing>
